# Copy to `.env.supabase.local` (gitignored) and fill in. Never commit real values.
#
# Dashboard → Account → Access Tokens: create a token for the Supabase CLI.
SUPABASE_ACCESS_TOKEN=

# Project ref from https://REF.supabase.co
SUPABASE_PROJECT_REF=qbmheroqblpcbuqwnzlp
# PostgREST: https://qbmheroqblpcbuqwnzlp.supabase.co/rest/v1/  (scripts use SUPABASE_URL below + /rest/v1/…)

# Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=

# Anon JWT or sb_publishable_… (same as iOS WCSLessonTextToVideoSupabaseAnonKey)
SUPABASE_ANON_OR_PUBLISHABLE_KEY=

# Shared between Edge secret WCS_JOB_LIST_SECRET and iOS WCS_LESSON_VIDEO_JOB_LIST_SECRET
WCS_JOB_LIST_SECRET=
